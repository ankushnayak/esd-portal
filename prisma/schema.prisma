generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PENDING_ALUMNI
  VERIFIED_ALUMNI
  VOLUNTEER_REVIEWER
  CITY_COORDINATOR
  CATEGORY_COORDINATOR
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  INVITED
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum BeneficiaryType {
  INDIVIDUAL
  FAMILY
  SCHOOL
  HOSPITAL
  COMMUNITY
  NGO
  OTHER
}

enum PublicVisibility {
  PRIVATE
  ANONYMIZED
  PUBLIC_WITH_CONSENT
}

enum SevaCaseStatus {
  DRAFT
  SUBMITTED
  CLARIFICATION_REQUESTED
  APPROVED
  REJECTED
}

enum AttachmentType {
  PROOF
  PHOTO
  CONSENT
  OTHER
}

enum ReviewAction {
  SUBMITTED
  APPROVED
  REJECTED
  CLARIFICATION_REQUESTED
  PUBLIC_VISIBILITY_UPDATED
  FEATURED_UPDATED
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  DRY_RUN
}

enum CertificatePeriodType {
  MONTHLY
  YEARLY
  CUSTOM
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  passwordHash        String?
  name                String
  phone               String?
  role                UserRole             @default(PENDING_ALUMNI)
  status              UserStatus           @default(ACTIVE)
  emailVerifiedAt     DateTime?
  cityScope           String[]
  categoryScopeIds    String[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  accounts            Account[]
  sessions            Session[]
  alumniProfile       AlumniProfile?
  sevaCases           SevaCase[]           @relation("SevaCaseOwner")
  approvedCases       SevaCase[]           @relation("ApprovedCases")
  rejectedCases       SevaCase[]           @relation("RejectedCases")
  uploadedAttachments Attachment[]         @relation("UploadedBy")
  caseReviews         CaseReview[]
  notifications       Notification[]
  certificates        Certificate[]
  userBadges          UserBadge[]
  auditLogs           AuditLog[]           @relation("ActorAuditLogs")
  settingsUpdated     Setting[]            @relation("SettingsUpdatedBy")
  reviewedProfiles    AlumniProfile[]      @relation("ProfileVerifiedBy")
  passwordResetTokens PasswordResetToken[]
}

model AlumniProfile {
  id                  String             @id @default(cuid())
  userId              String             @unique
  batchYear           Int?
  institution         String?
  program             String?
  profession          String?
  specialty           String?
  city                String?
  state               String?
  country             String             @default("India")
  profilePhotoUrl     String?
  publicProfileOptIn  Boolean            @default(false)
  sevaCategories      String[]
  availabilityPledge  String?
  verificationStatus  VerificationStatus @default(PENDING)
  verificationNotes   String?
  verifiedAt          DateTime?
  verifiedById        String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  verifiedBy          User?              @relation("ProfileVerifiedBy", fields: [verifiedById], references: [id])
}

model SevaCategory {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  description   String?
  parentId      String?
  isActive      Boolean        @default(true)
  sortOrder     Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  parent        SevaCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children      SevaCategory[] @relation("CategoryHierarchy")
  sevaCases     SevaCase[]     @relation("CaseCategory")
  subcategoryOf SevaCase[]     @relation("CaseSubcategory")
}

model SevaCase {
  id                  String             @id @default(cuid())
  caseNumber          String             @unique
  userId              String
  title               String
  date                DateTime
  categoryId          String
  subcategoryId       String?
  profession          String
  city                String
  state               String
  beneficiaryType     BeneficiaryType
  beneficiaryCount    Int
  description         String
  estimatedValue      Decimal            @db.Decimal(12, 2)
  actualAmount        Decimal            @db.Decimal(12, 2)
  currency            String             @default("INR")
  consentObtained     Boolean            @default(false)
  publicVisibility    PublicVisibility   @default(PRIVATE)
  publicSummary       String?
  internalNotes       String?
  featured            Boolean            @default(false)
  status              SevaCaseStatus     @default(DRAFT)
  submittedAt         DateTime?
  approvedAt          DateTime?
  approvedById        String?
  rejectedAt          DateTime?
  rejectedById        String?
  rejectionReason     String?
  clarificationNotes  String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  deletedAt           DateTime?
  user                User               @relation("SevaCaseOwner", fields: [userId], references: [id], onDelete: Cascade)
  category            SevaCategory       @relation("CaseCategory", fields: [categoryId], references: [id])
  subcategory         SevaCategory?      @relation("CaseSubcategory", fields: [subcategoryId], references: [id])
  approvedBy          User?              @relation("ApprovedCases", fields: [approvedById], references: [id])
  rejectedBy          User?              @relation("RejectedCases", fields: [rejectedById], references: [id])
  privateData         BeneficiaryPrivateData?
  attachments         Attachment[]
  reviews             CaseReview[]
}

model BeneficiaryPrivateData {
  id         String   @id @default(cuid())
  sevaCaseId String   @unique
  name       String?
  contact    String?
  location   String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  sevaCase   SevaCase @relation(fields: [sevaCaseId], references: [id], onDelete: Cascade)
}

model Attachment {
  id               String         @id @default(cuid())
  sevaCaseId       String
  uploadedById     String
  type             AttachmentType
  fileName         String
  fileUrl          String
  mimeType         String
  fileSize         Int
  isPublicEligible Boolean        @default(false)
  createdAt        DateTime       @default(now())
  sevaCase         SevaCase       @relation(fields: [sevaCaseId], references: [id], onDelete: Cascade)
  uploadedBy       User           @relation("UploadedBy", fields: [uploadedById], references: [id], onDelete: Cascade)
}

model CaseReview {
  id             String         @id @default(cuid())
  sevaCaseId     String
  reviewerId     String
  action         ReviewAction
  comments       String?
  previousStatus SevaCaseStatus?
  newStatus      SevaCaseStatus
  createdAt      DateTime       @default(now())
  sevaCase       SevaCase       @relation(fields: [sevaCaseId], references: [id], onDelete: Cascade)
  reviewer       User           @relation(fields: [reviewerId], references: [id], onDelete: Cascade)
}

model Notification {
  id                String             @id @default(cuid())
  userId            String?
  channel           NotificationChannel
  recipient         String
  templateKey       String
  subject           String?
  body              String
  status            NotificationStatus @default(PENDING)
  providerMessageId String?
  error             String?
  createdAt         DateTime           @default(now())
  sentAt            DateTime?
  user              User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model MessageTemplate {
  id        String              @id @default(cuid())
  key       String
  name      String
  channel   NotificationChannel
  subject   String?
  body      String
  isActive  Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@unique([key, channel])
}

model Certificate {
  id                  String                @id @default(cuid())
  userId              String
  periodType          CertificatePeriodType
  periodStart         DateTime
  periodEnd           DateTime
  totalCases          Int
  totalValue          Decimal               @db.Decimal(12, 2)
  beneficiariesHelped Int
  certificateNumber   String                @unique
  pdfUrl              String?
  issuedAt            DateTime              @default(now())
  user                User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Badge {
  id           String     @id @default(cuid())
  key          String     @unique
  name         String
  description  String
  icon         String?
  criteriaJson Json
  userBadges   UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  awardedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

model AuditLog {
  id           String   @id @default(cuid())
  actorId      String?
  action       String
  entityType   String
  entityId     String
  metadataJson Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  actor        User?    @relation("ActorAuditLogs", fields: [actorId], references: [id], onDelete: SetNull)
}

model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  valueJson   Json
  updatedById String?
  updatedAt   DateTime @updatedAt
  updatedBy   User?    @relation("SettingsUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  token      String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  consumedAt DateTime?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
